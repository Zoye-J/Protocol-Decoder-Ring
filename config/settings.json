{
    "sandbox": {
        "timeout_seconds": 300,
        "max_memory_mb": 1024,
        "network_isolation": true,
        "capture_all_traffic": true,
        "temp_dir_prefix": "pdr_sandbox_"
    },
    "packet_capture": {
        "interface": null,
        "capture_filter": "",
        "max_packets": 10000,
        "capture_timeout": 60,
        "pcap_output_dir": "output/captures",
        "buffer_size": 65536,
        "promiscuous_mode": false,
        "monitor_mode": false
    },
    "protocol_analysis": {
        "entropy_threshold": 0.8,
        "suspicious_ports": [22, 23, 53, 445, 3389, 4444, 5555, 6667, 8080, 8443],
        "known_malicious_domains": [],
        "dns_tunneling_threshold": 0.7
    },
    "exfiltration_detection": {
        "data_rate_threshold_kbps": 100,
        "packet_size_variance_threshold": 50,
        "timing_analysis_window": 10,
        "steganography_check": true,
        "suspicious_extensions": [".jpg", ".png", ".zip", ".rar", ".docx", ".pdf"],
        "suspicious_ip_ranges": ["45.", "46.", "5.", "185.", "188.", "193.", "194.", "195."],
        "exfiltration": {
            "outbound_threshold_mb": 10,
            "suspicious_countries": [],
            "unusual_ports": [21, 22, 53, 123, 443, 8080],
            "covert_channel_detection": true,
            "dns_exfiltration_detection": true,
            "icmp_exfiltration_detection": true,
            "http_exfiltration_detection": true
        }
    },
    "signature_generation": {
        "snort_version": "2.9",
        "suricata_compatible": true,
        "yara_rules": true,
        "sigma_rules": true,
        "min_confidence": 0.7,
        "max_signatures_per_pattern": 5,
        "include_payload": true,
        "include_metadata": true,
        "default_priority": 2,
        "signature_author": "PDR"
    },
    "reporting": {
        "output_dir": "reports",
        "html_templates": true,
        "json_output": true,
        "pdf_output": false
    },
    "logging": {
        "level": "INFO",
        "file": "logs/pdr.log",
        "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    }
}